# ──────────────────────────────────────────────────────────────
#  Rust (workspace)
# ──────────────────────────────────────────────────────────────
/target/
**/*.rs.bk
*.pdb
# Cargo.lock SÍ se sube (es un binario/app, no una librería)

# ──────────────────────────────────────────────────────────────
#  Datos del motor / base de datos embebida (redb)
# ──────────────────────────────────────────────────────────────
**/*.redb
**/*.redb.lock
nucleus_data/
nucleus_demo/
*.bak
*.diff.bak

# ──────────────────────────────────────────────────────────────
#  Secretos / tokens / configuración local
# ──────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*token*.txt
admin_token.txt
nucleus_admin_token.txt
*.pem
*.key

# ──────────────────────────────────────────────────────────────
#  Artefactos de release / instaladores
# ──────────────────────────────────────────────────────────────
/dist/
*.zip
*.tar.gz

# ──────────────────────────────────────────────────────────────
#  Cliente y ejemplos C# / .NET
# ──────────────────────────────────────────────────────────────
**/bin/
**/obj/
*.user
*.suo
.vs/

# ──────────────────────────────────────────────────────────────
#  Cliente y ejemplos TypeScript / JavaScript / Node
# ──────────────────────────────────────────────────────────────
**/node_modules/
clients/typescript/dist/
*.tsbuildinfo
npm-debug.log*
yarn-error.log*

# ──────────────────────────────────────────────────────────────
#  Logs y temporales
# ──────────────────────────────────────────────────────────────
*.log
*.tmp
tmp/
temp/

# ──────────────────────────────────────────────────────────────
#  IDE / editores
# ──────────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*~

# ──────────────────────────────────────────────────────────────
#  Sistema operativo
# ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
